# ──────────────────────────────────────────────────────────────────
# Frontend (Vite) — these MUST be prefixed with VITE_
# ──────────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Same Gemini key but exposed to the client for client-side image gen.
# (Server-side Gemini calls read GEMINI_API_KEY from functions/.env.)
GEMINI_API_KEY=""

# ──────────────────────────────────────────────────────────────────
# Backend (Cloud Functions) — copy these into functions/.env.<projectId>
# ──────────────────────────────────────────────────────────────────
# See https://firebase.google.com/docs/functions/config-env

# Required
GEMINI_API_KEY=""
GOOGLE_PLACES_API_KEY=""

# OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""

CANVA_CLIENT_ID=""
CANVA_CLIENT_SECRET=""

# Public app URL — used to build OAuth redirect targets and post-callback redirects.
# In production, this is the Firebase Hosting URL (or your custom domain).
APP_URL="https://your-project.web.app"

# Go High Level (Social Planner API)
# In HighLevel: Settings → Private Integrations → create/edit integration and enable scopes:
#   socialplanner/account.readonly — list connected social accounts
#   socialplanner/post.readonly — queued posts / calendar (posts/list)
#   socialplanner/post.write — schedule posts
#   users.readonly — optional; Settings "Fetch users" / default user id lookup
GHL_PRIVATE_INTEGRATION_TOKEN=""
# Optional JSON map: locationId → Private Integration token
# Example: GHL_LOCATION_TOKENS={"xYz123AbC":"pit-...","anotherLocId":"pit-..."}
GHL_LOCATION_TOKENS=""
GHL_API_VERSION="2021-07-28"
GHL_USER_ID=""
GHL_COMPANY_ID=""

# ScrapeCreators (Social Analytics + Prospecting Facebook lookups)
SCRAPECREATORS_API_KEY=""

# Local dev only — bypass Firebase ID token verification on /api/*
# DO NOT set this in production deployments.
ALLOW_UNAUTHENTICATED="true"

# Local dev only — port for the Express dev server (matches vite.config.ts proxy).
SERVER_PORT=3001

# Local scripts (scripts/add-team-member.ts) — path to service account JSON
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/serviceAccount.json"
# FIREBASE_PROJECT_ID=""
