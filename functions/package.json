{
  "name": "bdai-functions",
  "private": true,
  "version": "1.0.0",
  "description": "BDAi Agency backend (Firebase Cloud Functions Gen 2)",
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "dev": "tsx watch src/dev-server.ts",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "npm run build && firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@gohighlevel/api-client": "^2.2.2",
    "@google/genai": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^6.5.0",
    "googleapis": "^171.4.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "dotenv": "^17.2.3",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
